{
  "use_mock": false,
  "sources": {
    "greenhouse": true,
    "lever": true,
    "arbeitnow": true,
    "infojobs_html": false,
    "indeed_html": false,
    "tecnoempleo_html": false,
    "generic_html": false
  },
  "html_collectors": {
    "enabled": false,
    "reason": "Disabled by default because HTML search pages can mix navigation/category links with real jobs."
  },
  "source_registry": {
    "greenhouse": {
      "enabled": true,
      "kind": "greenhouse_job_board_api",
      "timeout_seconds": 20,
      "companies": [
        { "name": "GitLab", "board": "gitlab", "enabled": true },
        { "name": "Mozilla", "board": "mozilla", "enabled": true },
        { "name": "Okta", "board": "okta", "enabled": true },
        { "name": "Cloudflare", "board": "cloudflare", "enabled": true }
      ]
    },
    "lever": {
      "enabled": true,
      "kind": "lever_postings_api",
      "timeout_seconds": 20,
      "companies": [
        { "name": "Wealthfront", "company": "wealthfront", "enabled": true }
      ]
    },
    "arbeitnow": {
      "enabled": true,
      "kind": "public_remote_technical_api",
      "timeout_seconds": 20,
      "max_pages": 1
    }
  },
  "max_pages_per_query": 1,
  "delay_seconds": 0,
  "use_playwright": false,
  "locations": [
    "Valencia",
    "Paterna",
    "Burjassot"
  ],
  "general_queries": [
    "dependiente",
    "cajero",
    "reponedor",
    "mozo almacen",
    "auxiliar administrativo",
    "atencion al cliente",
    "recepcionista",
    "operario",
    "limpieza",
    "hosteleria"
  ],
  "technical_queries": [
    "programador",
    "desarrollador",
    "frontend",
    "backend",
    "full stack",
    "Java",
    "JavaScript",
    "TypeScript",
    "Vue",
    "Angular",
    "HTML",
    "CSS",
    "SCSS",
    "Figma",
    "MongoDB",
    "MySQL",
    "diseno web",
    "informatico",
    "soporte tecnico"
  ]
}
